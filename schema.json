{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "NZUG-1.0 Convention",
  "description": "Schema for NZUG-1.0 (NetCDF Zarr Users Guide) convention — structural interoperability layer for scientific array conventions on Zarr v3",
  "type": "object",
  "properties": {
    "zarr_format": {
      "type": "integer",
      "const": 3,
      "description": "Zarr format version"
    },
    "node_type": {
      "type": "string",
      "enum": ["array", "group"],
      "description": "Type of Zarr node"
    },
    "attributes": {
      "type": "object",
      "description": "Zarr attributes containing convention metadata and properties",
      "properties": {
        "zarr_conventions": {
          "type": "array",
          "description": "Array of convention metadata objects",
          "contains": {
            "$ref": "#/$defs/conventionMetadata"
          }
        }
      },
      "required": ["zarr_conventions"]
    }
  },
  "required": ["zarr_format", "node_type", "attributes"],
  "additionalProperties": true,
  "allOf": [
    {
      "if": {
        "properties": {
          "node_type": { "const": "group" }
        }
      },
      "then": {
        "$ref": "#/$defs/groupRequirements"
      }
    },
    {
      "if": {
        "properties": {
          "node_type": { "const": "array" }
        }
      },
      "then": {
        "$ref": "#/$defs/arrayRequirements"
      }
    }
  ],
  "$defs": {
    "conventionMetadata": {
      "type": "object",
      "description": "NZUG-1.0 convention metadata object for use in zarr_conventions array",
      "properties": {
        "schema_url": {
          "type": "string",
          "const": "https://raw.githubusercontent.com/zarr-conventions/nzug/refs/tags/v1/schema.json",
          "description": "URL to the JSON Schema definition for this convention"
        },
        "spec_url": {
          "type": "string",
          "const": "https://github.com/zarr-conventions/nzug/blob/v1/README.md",
          "description": "URL to the full specification document"
        },
        "uuid": {
          "type": "string",
          "const": "d0a980b5-c644-4dcc-85a1-283799a58f40",
          "description": "UUID that permanently identifies this convention"
        },
        "name": {
          "type": "string",
          "const": "NZUG-1.0",
          "description": "Human-readable name of the convention"
        },
        "description": {
          "type": "string",
          "description": "Brief description of the convention's purpose"
        }
      },
      "anyOf": [
        { "required": ["schema_url"] },
        { "required": ["spec_url"] },
        { "required": ["uuid"] }
      ],
      "additionalProperties": false
    },
    "dtypeString": {
      "type": "string",
      "description": "Type identifier: either a NumPy dtype string ([endian][kind][size], e.g. '<f4') or a Zarr v3 data type name (e.g. 'float32')",
      "anyOf": [
        {
          "pattern": "^[<>|][iufS][0-9]+$",
          "description": "NumPy dtype string"
        },
        {
          "enum": [
            "bool",
            "int8",
            "uint8",
            "int16",
            "uint16",
            "int32",
            "uint32",
            "int64",
            "uint64",
            "float32",
            "float64",
            "complex64",
            "complex128"
          ],
          "description": "Zarr v3 data type name"
        }
      ]
    },
    "nczarrAttr": {
      "type": "object",
      "description": "The _nczarr_attr attribute: NCZarr-compatible attribute type annotations",
      "properties": {
        "types": {
          "type": "object",
          "description": "Maps attribute names to type identifier strings (NumPy dtype or Zarr v3 data type)",
          "additionalProperties": {
            "$ref": "#/$defs/dtypeString"
          }
        }
      },
      "required": ["types"],
      "additionalProperties": false
    },
    "groupRequirements": {
      "type": "object",
      "description": "Requirements specific to group nodes in NZUG-1.0",
      "properties": {
        "attributes": {
          "type": "object",
          "properties": {
            "conventions": {
              "type": "string",
              "pattern": "NZUG-1\\.0",
              "description": "Space-separated convention identifiers; MUST include NZUG-1.0"
            },
            "_nczarr_attr": {
              "$ref": "#/$defs/nczarrAttr"
            }
          },
          "required": ["conventions"]
        }
      }
    },
    "arrayRequirements": {
      "type": "object",
      "description": "Requirements specific to array nodes in NZUG-1.0",
      "properties": {
        "shape": {
          "type": "array",
          "items": { "type": "integer", "minimum": 0 },
          "description": "Array shape"
        },
        "dimension_names": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "description": "Dimension labels; MUST have same length as shape; no null or empty entries"
        },
        "data_type": {
          "type": "string",
          "description": "Array data type"
        },
        "attributes": {
          "type": "object",
          "properties": {
            "_FillValue": {
              "description": "Semantic missing data indicator"
            },
            "_nczarr_attr": {
              "$ref": "#/$defs/nczarrAttr"
            }
          },
          "additionalProperties": true
        }
      },
      "required": ["dimension_names", "shape"]
    }
  }
}
